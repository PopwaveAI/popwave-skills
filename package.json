{
  "name": "popwave-skills",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "prepare": "npm run hooks:install",
    "skills:sync": "git submodule update --init --recursive",
    "skills:new": "node scripts/new-skill.mjs",
    "skills:validate": "node scripts/validate-skills.mjs",
    "skills:build": "node scripts/build-registry.mjs",
    "build": "npm run skills:validate && npm run skills:build"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
