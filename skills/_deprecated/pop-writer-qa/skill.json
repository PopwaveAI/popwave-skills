{
  "id": "pop-writer-qa",
  "version": "1.0.1",
  "displayName": "项目审计",
  "description": "项目审计 / 全量对齐检查 触发：四维工程级扫描（文件树/文档质量/管线阶段/分类正确性），输出 Gap Report。",
  "entry": "SKILL.md",
  "category": "qa",
  "scenario": "audit",
  "mode": "report",
  "recommended": 8,
  "tags": [
    "修订与质量保障"
  ],
  "fidelity": "production",
  "novelAgentVersion": "v3.3",
  "directory": "pop-writer-qa",
  "orchestration": {
    "preflight": [
      "check_project_dir"
    ],
    "dependencies": [
      "project.yaml",
      "expert-writer/references/pipeline-arch.md"
    ],
    "injectContext": [
      "project.yaml"
    ],
    "subagentRequired": false
  },
  "produces": [
    "项目全量对齐审计报告（Gap Report）"
  ],
  "activation": {
    "slashCommands": [
      "审计",
      "体检",
      "对齐检查",
      "审项目"
    ],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true
  },
  "pipeline": {
    "upstream": [
      "pop-writer-prose"
    ],
    "downstream": []
  }
}
