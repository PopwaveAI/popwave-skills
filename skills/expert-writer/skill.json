{
  "id": "expert-writer",
  "version": "10.0.0",
  "displayName": "写作专家",
  "description": "Pop应用强制入口写作专家调度器。每次写作请求都会先启用本skill；它负责识别意图、判断项目阶段、读取目标子skill、装配上下文并路由到seed/plot/create/revise/arc。它不亲自设计剧情、不默认审稿，只执行轻调度。",
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": [
      "写作专家",
      "专家模式",
      "expert-writer"
    ],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": false,
    "network": false
  },
  "pipeline": {
    "upstream": [],
    "downstream": [
      "pop-decon",
      "pop-writer-v3-seed",
      "pop-writer-v3-plot",
      "pop-writer-v3-create",
      "pop-writer-v3-revise",
      "pop-writer-v3-arc",
      "pop-research"
    ]
  }
}
