{
  "id": "pop-novel-qa",
  "version": "0.6.0",
  "displayName": "爽点QA",
  "description": "审稿/质检/QA/审一下/爽点质检/项目审计 触发：Step 0 全量项目对齐审计 / Step 1 大纲层QC / Step 2 骨架层QC / Step 3 正文层QC。",
  "entry": "SKILL.md",
  "category": "qa",
  "scenario": "review",
  "mode": "report",
  "recommended": 7,
  "tags": ["QC", "质检", "审稿", "感受报告", "项目审计"],
  "fidelity": "production",
  "novelAgentVersion": "v3.3",
  "directory": "pop-novel-qa",
  "orchestration": {
    "preflight": ["check_project_dir"],
    "dependencies": ["project.yaml", "expert-writer/references/pipeline-arch.md"],
