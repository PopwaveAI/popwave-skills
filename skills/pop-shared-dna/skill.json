{
  "id": "pop-shared-dna",
  "version": "4.2.0",
  "displayName": "文风DNA蒸馏引擎",
  "description": "文风DNA蒸馏引擎。当用户说'提取文风''文风DNA''风格蒸馏''分析作者笔触'时启用。从原文按场景类型提取笔触产出prose-render可对照的场景参考文件。",
  "category": "writing",
  "scenario": "production",
  "mode": "style",
  "recommended": 3,
  "tags": ["创意与研究"],
  "fidelity": "production",
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": ["pop-shared-dna", "文风蒸馏"],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": false
  },
  "orchestration": {
    "preflight": [],
    "dependencies": [],
    "inject_context": []
  },
  "produces": [
    "文风DNA档案（写作资产/文风库/作者名-书名.md, 分析+写前指令合一）",
    "示例产出（试写片段）"
  ],
  "pipeline": {
    "upstream": [
      "pop-decon"
    ],
    "downstream": [
      "pop-writer-prose",
      "pop-writer-v3-seed",
      "pop-writer-v3-revise"
    ]
  }
}
