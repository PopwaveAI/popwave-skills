{
  "id": "pop-shared-dna",
  "version": "5.1.0",
  "displayName": "文风DNA蒸馏引擎",
  "description": "从作者/书籍原文中提取章内文风DNA（文笔笔触+单章剧情套路），生成可供 prose-render 对照、也可供涌现式写作 current-state/soul/write/review 消费的执行契约。",
  "category": "writing",
  "scenario": "production",
  "mode": "style",
  "recommended": 3,
  "tags": [
    "文风",
    "DNA",
    "风格蒸馏",
    "模仿",
    "写作",
    "提示词"
  ],
  "fidelity": "production",
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": [
      "pop-shared-dna",
      "DNA",
      "文风蒸馏",
      "风格模仿",
      "style-mimic",
      "章内文风DNA",
      "单章套路DNA"
    ],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": false
  },
  "orchestration": {
    "preflight": [],
    "dependencies": [],
    "inject_context": []
  },
  "produces": [
    "章内文风DNA档案（写作资产/文风库/作者名-书名.md, 分析+写前指令合一）",
    "示例产出（试写片段）"
  ],
  "pipeline": {
    "upstream": [
      "pop-decon"
    ],
    "downstream": [
      "pop-writer-prose",
      "pop-novel-seed",
      "pop-novel-revise",
      "pop-qidian-write",
      "pop-qidian-review"
    ]
  }
}
