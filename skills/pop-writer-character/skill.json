{
  "id": "pop-writer-character",
  "version": "2.0.3",
  "displayName": "角色分级模板",
  "description": "当用户说'设计角色/创建角色卡/写人设/设计配角/角色分级/角色模板/角色储备'时启用。按角色叙事权重选择 Lv1~Lv4 模板，产出标准化角色卡，供 pop-writer-creative、pop-writer-plot、pop-writer-chapter 及独立角色储备设计消费。",
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": [
      "角色分级模板",
      "角色模板",
      "character-schema",
      "角色设计"
    ],
    "default": false
  },
  "pipeline": {
    "upstream": [
      "pop-writer-creative"
    ],
    "downstream": [
      "pop-writer-plot",
      "pop-writer-chapter"
    ],
    "produces": [
      "设计/角色层/{角色名}-{定位}.md"
    ]
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": false
  }
}
