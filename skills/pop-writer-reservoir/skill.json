{
  "id": "pop-writer-reservoir",
  "version": "4.0.0",
  "displayName": "采风转化引擎",
  "description": "采风转化引擎 v4.0.0。深层域研究（四层穿透L1-L4）→ 域DNA档案 → 四层转化（素材来源/转化手法/跨域联动/叙事语法）→ 剧情储备卡或设定储备卡。三模式：被creative调用/独立调起/主动丰富。安全门禁+权重矩阵+质量闸门（含转化深度闸门G）。",
  "pipeline": {
    "upstream": ["pop-writer-creative"],
    "downstream": ["pop-writer-plot", "pop-writer-world", "pop-writer-character"],
    "references": ["pop-trope-library"]
  },
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": ["注入素材", "素材储备", "储备池", "热点内化", "内化", "pool"],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": true
  }
}
