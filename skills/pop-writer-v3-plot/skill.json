{
  "id": "pop-writer-v3-plot",
  "version": "2.0.0",
  "displayName": "剧情单元运行器",
  "description": "正向原创剧情单元运行与幕纲编译。从seed的故事种子、硬设定、设定缺口和活记忆出发，生成状态契约、章节事件仿真日志、设定账本和编译后的单元卡。核心是先运行故事再提取结构，不直接填表式写幕纲。",
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": ["幕纲", "剧情单元", "plot", "运行日志", "单元卡"],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": false,
    "network": false
  },
  "pipeline": {
    "upstream": ["pop-writer-v3-seed", "pop-trope-library"],
    "downstream": ["pop-writer-v3-create", "expert-writer"]
  }
}
