{
  "name": "prd-builder",
  "version": "1.0.0",
  "description": "从产品想法到 PRD 到飞书文档到交互 Demo 的全流程自动化",
  "triggers": [
    "做PRD", "产品需求文档", "产品原型", "交互Demo",
