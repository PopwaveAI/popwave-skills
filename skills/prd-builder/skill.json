    "从想法到产品", "产品概念", "生成demo"
  ],
  "depends_on": ["feishu-docs"],
  "references": {
    "kol_templates": "references/kol_templates.json",
    "platform_benchmarks": "references/platform_benchmarks.json",
    "prd_structure": "references/prd_structure.md",
    "demo_framework": "references/demo_framework.md"
  },
  "workflow_phases": [
    "Phase 1: 需求澄清 (AskUserQuestion)",
    "Phase 2: PRD生成 + 飞书同步",
    "Phase 3: 飞书反馈处理 (汇总模式/自动处理模式)",
    "Phase 4: 生成交互Demo (单HTML)"
