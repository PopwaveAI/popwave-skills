{
  "id": "tool-cnovel-research",
  "version": "1.1.1",
  "displayName": "tool-cnovel-research",
  "description": "网文作者社区用户调研专用技能。整合 AnySearch 搜索引擎 + 各平台 API + 绕过策略，覆盖龙空/晋江/阅文/贴吧/知乎/豆瓣/微博/B站/小红书/抖音/微信公众号/视频号等 12+ 平台。对高可采集平台全自动出报告；对低可采集平台提供标准人工兜底流程。",
  "tags": [
    "调研与内容采集"
  ],
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": [
      "tool-cnovel-research"
    ],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": true,
    "shell": true
  },
  "loadPolicy": {
    "includeReferences": "on-demand",
    "maxPromptChars": 40000
  },
  "pipeline": {
    "upstream": [],
    "downstream": [
      "tool-opinion-tracker"
    ]
  },
  "dependencies": {
    "python": [],
    "env": [],
    "api": {}
  }
}
