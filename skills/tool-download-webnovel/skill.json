{
  "id": "tool-download-webnovel",
  "version": "3.0.1",
  "displayName": "授权直链下载小说TXT",
  "description": "从用户提供的授权 TXT/ZIP 直链或本地文件导入小说文本，自动下载/复制、解压、转 UTF-8、校验内容，供 pop-decon 使用。主路径是直链下载；不绕过登录/付费/提取码/反爬限制，不逐章抓取受保护网站。",
  "pipeline": {
    "upstream": [],
    "downstream": [
      "pop-decon"
    ]
  },
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": [
      "导入小说TXT",
      "直链下载TXT",
      "下载授权TXT",
      "校验小说TXT",
      "tool-download-webnovel"
    ],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": true,
    "shell": true
  },
  "loadPolicy": {
    "includeReferences": "on-demand",
    "maxPromptChars": 20000
  }
}
