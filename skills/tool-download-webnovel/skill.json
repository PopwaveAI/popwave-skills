{
  "id": "tool-download-webnovel",
  "version": "6.1.0",
  "displayName": "网文搜索下载TXT",
  "description": "搜索并下载中文网文 TXT：自动搜索直链 → 作者验证 → 下载/爬取 → 校验。支持 80ge.info 反盗链直链、笔趣阁逐章爬取、批量下载。默认排除付费墙正版网站（起点/晋江/纵横等）。三层防下错书：作者验证+作品集页检测+内容校验。",
  "pipeline": {
    "upstream": [],
    "downstream": [
      "pop-decon"
    ]
  },
  "entry": "SKILL.md",
  "activation": {
    "slashCommands": [
      "下载小说",
      "搜索下载TXT",
      "导入TXT",
      "爬取小说",
      "下载TXT",
      "tool-download-webnovel"
    ],
    "default": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": true,
    "shell": true
  },
  "loadPolicy": {
    "includeReferences": "on-demand",
    "maxPromptChars": 20000
  }
}
