{
  "id": "tool-download-webnovel",
  "version": "7.1.0",
  "displayName": "网文搜索下载TXT",
  "description": "网文搜索下载。当用户说'下载小说''搜索网文'时启用。输入书名+作者输出TXT文件。三阶段SOP：脚本搜索→web搜索兜底→验证交付。默认排除付费墙正版网站。",
  "tags": ["工具"],
  "pipeline": {
    "upstream": [],
    "downstream": [
      "pop-decon"
    ]
  },
  "entry": "SKILL.md",
  "activation": { "slashCommands": ["下载小说", "tool-download-webnovel"], "default": false },
  "permissions": {
    "readProjectFiles": true,
    "writeProjectFiles": true,
    "network": true,
    "shell": true
  },
  "loadPolicy": {
    "includeReferences": "on-demand",
    "maxPromptChars": 20000
  }
